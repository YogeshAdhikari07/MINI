<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EazyShare - Collaborative Note Sharing Platform</title>
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container">
            <div class="logo">Eazy share</div>
            <div class="nav-links">
                <a href="#features">Features</a>
                <a href="#how-it-works">How It Works</a>
                <a href="#user-types">For You</a>
                <a href="/user/adminlogin">Admin</a>
                <a href="/user/sign" class="btn btn-primary">Get Started</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Quality Notes, Shared Knowledge</h1>
            <p>A curated platform where expert teachers and administrators share comprehensive study materials with students. Learn from the best, access anytime.</p>
            <div class="hero-buttons">
                <a href="/user/studentlogin" class="btn btn-secondary btn-large">Login</a>
                <a href="/user/teacher-login" class="btn btn-primary btn-large">Teacher Login</a>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features" id="features">
        <h2 class="section-title1">Why Choose Eazy Share?</h2>
        <p class="section-subtitle">Everything you need for collaborative learning in one place</p>
        
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🎓</div>
                <h3>Expert-Curated Content</h3>
                <p>Only verified teachers and administrators can upload notes, ensuring high-quality, accurate study materials for all students.</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">📥</div>
                <h3>Easy Downloads</h3>
                <p>Students can instantly download any note in multiple formats. Access your study materials offline, anytime you need them.</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h3>Smart Search</h3>
                <p>Find exactly what you need with powerful search and filtering by subject, topic, teacher, or grade level.</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3>Secure & Organized</h3>
                <p>Role-based access control keeps content organized and secure. Teachers manage content, students focus on learning.</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Bookmark notes</h3>
                <p>Students can bookmark favorite notes.</p>
            </div>
            
            <div class="feature-card">
                <div class="feature-icon">🌐</div>
                <h3>Access Anywhere</h3>
                <p>Cloud-based platform accessible from any device. Study on your phone, tablet, or computer seamlessly.</p>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="how-it-works" id="how-it-works">
        <h2 class="section-title1">How It Works</h2>
        <p class="section-subtitle">Simple, streamlined, and effective</p>
        
        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <h3>Create Account(only for teachers)  </h3>
                <p>Sign up as ateacher, or admin. Verification ensures content quality and security.</p>
            </div>
            
            <div class="step">
                <div class="step-number">2</div>
                <h3>Upload or Browse</h3>
                <p>Teachers upload comprehensive notes. Students browse and discover quality study materials.</p>
            </div>
            
            <div class="step">
                <div class="step-number">3</div>
                <h3>Learn & Share</h3>
                <p>Download notes instantly, study effectively, and build your knowledge library.</p>
            </div>
        </div>
    </section>

    <!-- User Types -->
    <section class="user-types" id="user-types">
        <h2 class="section-title">Built for Every Role</h2>
        <p class="section-subtitle">Tailored features for teachers, admins, and students</p>
        
        <div class="user-types-grid">
            <div class="user-card">
                <h3>👨‍🏫 Teachers</h3>
                <p>Share your expertise with students</p>
                <ul>
                    <li>Upload notes in any format</li>
                    <li>Organize by subject & topic</li>
                    <li>Update materials anytime</li>
                    <li>See download statistics</li>
                    <li>Help students succeed</li>
                </ul>
            </div>
            
            <div class="user-card">
                <h3>👥 Admins</h3>
                <p>Manage and moderate content</p>
                <ul>
                    <li>Full content control</li>
                    <li>Verify teacher accounts</li>
                    <li>Monitor platform activity</li>
                    <li>Ensure quality standards</li>
                    <li>Generate reports</li>
                </ul>
            </div>
            
            <div class="user-card">
                <h3>📚 Students</h3>
                <p>Access quality study materials</p>
                <ul>
                    <li>Browse all available notes</li>
                    <li>Download unlimited content</li>
                    <li>Search by topic</li>
                    <li>Bookmark favorites</li>
                    <li>Learn at your pace</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <h2>Ready to Transform Your Learning?</h2>
        <p>Join thousands of students and educators already sharing knowledge</p>
        <div class="hero-buttons">
            <a href="#" class="btn btn-primary btn-large">Get Started Free</a>
            <a href="#" class="btn btn-secondary btn-large">Contact Us</a>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy;EazyShare. Notes as they should be clean and organized </p>
    </footer>
    <script src="/js/index.js"></script>
</body>
</html>
