<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EazyShare -Collaborative Note Sharing Platform</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/user.css"/>
</head>
<body>
    <nav class="flex flex-row justify-between px-12 py-4 items-center border-b-2">
        <h1 class="text-2xl font-bold">Eazy Share</h1>
        <h1><%=user.username%></h1>
    </nav>
    <div class="sideBar border-r-3">
        <ul>
            <li><img class="h-[1.2rem]" src="/svgImg/notes.svg" alt="Notes">Notes</li>
            <li><img class="h-[1.2rem]" src="/svgImg/user.svg" alt="User">Users</li>
            <li><img class="h-[1.2rem]" src="/svgImg/logout.svg" alt="Logout">Logout</li>
        </ul>
    </div>
</body>
</html>