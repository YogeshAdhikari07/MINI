<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EazyShare -Collaborative Note Sharing Platform</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/user.css"/>
</head>
<body>
    <nav class="flex flex-row justify-between px-12 py-4 items-center border-b-2">
        <h1 class="text-2xl font-bold">Eazy Share</h1>
        <h1><%=user.username%></h1>
    </nav>
    <div class="sideBar border-r-3">
        <ul>
            <li><button type="button" id="notes-btn" class="flex flex-row gap-2 items-center px-4 py-2"><img class="h-[1.2rem]" src="/svgImg/notes.svg" alt="Notes">Notes</button></li>
            <li><button type="button" id="users-btn" class="flex flex-row gap-2 items-center px-4 py-2"><img class="h-[1.2rem]" src="/svgImg/user.svg" alt="User">Users</button></li>
            <li><button type="button" id="logout-btn" class="flex flex-row gap-2 items-center px-4 py-2"><img class="h-[1.2rem]" src="/svgImg/logout.svg" alt="Logout">Logout</button></li>
        </ul>
    </div>
    <div class="notes">
        <div class="nav flex flex-row justify-between items-center px-6 py-4">
            <span class="text-2xl font-bold" id="section-name-notes">Notes</span>
        </div>
        <div class="semesters flex flex-col gap-2 px-4 py-2">
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-lime-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> First Semester</span>
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-orange-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> Second Semester</span>
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-blue-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> Third Semester</span>
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-yellow-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> Fourth Semester</span>
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-red-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> Fifth Semester</span>
            <span class="px-4 py-3 border-2 rounded flex flex-row gap-2 items-center hover:bg-green-300"><img class="h-[1.3rem]" src="/svgImg/folder.svg" alt="folder"> Sixth Semester</span>
        </div>
    </div>
    <div class="user hidden">
        <div class="nav flex flex-row justify-between items-center px-6 py-4">
            <span class="text-2xl font-bold" id="section-name-user">Users</span>
            <button class="flex items-center gap-2 px-4 py-2 border-2 rounded hover:bg-[#FDFBD4]" id="add-btn"><img class="h-[1.3rem]" src="/svgImg/upload.svg" alt="Upload">Add Document</button>
        </div>
    </div>
    <script>
        const notesBtn = document.getElementById('notes-btn');
        const usersBtn = document.getElementById('users-btn');
        const logoutBtn = document.getElementById('logout-btn');
        notesBtn.addEventListener('click', () => {
            document.querySelector('body').style.gridTemplateAreas=`"nav nav" "sidebar notes"`;
            document.querySelector('.notes').classList.remove('hidden');
            document.querySelector('.user').classList.add('hidden');
        })
        usersBtn.addEventListener('click', () => {
            document.querySelector('body').style.gridTemplateAreas=`"nav nav" "sidebar user"`;
            document.querySelector('.notes').classList.add('hidden');
            document.querySelector('.user').classList.remove('hidden');
        })
        logoutBtn.addEventListener('click',async () => {
            await fetch("/user/logout", {
                method: "POST",
                credentials: "include"
            });
            window.location.href = "/";
        })
    </script>
</body>
</html>